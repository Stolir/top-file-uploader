<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/global.css">
    <title><%= title %></title>
  </head>
  <body>
    <%- include('partials/navbar') %>
    <section class="form-container">
      <h1 ><%= title %></h1>
      <form action="/signup" method="post" class="signup">
        <div>
          <label for="firstName">First Name</label>
          <input type="text" id="firstName" name="first_name" value="<%= data?.first_name || '' %>" required />
          <% if (errors?.first_name) { %>
            <span class="error"><%= errors.first_name %></span>
          <% } %>
        </div>
        <div>
          <label for="username">Username</label>
          <input type="text" id="username" name="username" value="<%= data?.username || '' %>" required />
          <% if (errors?.username) { %>
            <span class="error"><%= errors.username %></span>
          <% } %>
        </div>
        <div>
          <label for="email">Email</label>
          <input type="email" id="email" name="email" value="<%= data?.email || '' %>" required>
          <% if (errors?.username) { %>
           <span class="error"><%= errors.email %></span>
          <% } %>
        </div>
        <div class="passwordsContainer">
          <div>
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required />
            <% if (errors?.password) { %>
              <span class="error"><%= errors.password %></span>
            <% } %>
          </div>
          <div>
            <label for="confirmPassword">Confirm Password</label>
            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              required
            />
            <% if (errors?.confirmPassword) { %>
              <span class="error"><%= errors.confirmPassword %></span>
            <% } %>
          </div>
        </div>
        <button type="submit">Sign Up</button>
      </form>
    </section>
  </body>
</html>
