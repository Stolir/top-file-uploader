<dialog id="createNew">
  <button type="button" id="createNew_Folder">New Folder</button>
  <button type="button" id="createNew_File">Upload File</button>
</dialog>

<dialog id="createFolder" <%= openDialog === 'createFolder' ? "open" : '' %>>
  <form action="<%= currentFolder ? `/folders/${currentFolder}` : '/folders' %>" method="post">
    <% errors.forEach(error => { %>
     <span class="error"><%= error.msg %></span>
    <% }) %>
    <input
      type="text"
      placeholder="New Folder"
      name="name"
      id="folder_name"
      required
    />
    <button type="submit">Create</button>
    <button type="button" class="close-dialog">Cancel</button>
  </form>
</dialog>

<dialog id="createFile" <%= openDialog === 'createFile' ? 'open' : '' %>>
  <form action="<%= currentFolder ? `/files/${currentFolder}` : '/files' %>" method="post" enctype="multipart/form-data">
  <input type="file" name="file" required accept=".txt,.pdf,.docx,image/*"
/>
    <button type="submit">Create</button>
    <button type="button" class="close-dialog">Cancel</button>
</form>
</dialog>